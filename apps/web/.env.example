# Copy to .env.local and adjust credentials.
# Do not add ?options=search_path — node-pg can mis-connect on Windows; the app runs SET search_path after connect.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/royale_one

# Optional: allow GET /api/health/db when running next start (NODE_ENV=production)
# ALLOW_DB_HEALTH=1
